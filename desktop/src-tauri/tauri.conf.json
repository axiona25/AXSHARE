{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AXSHARE",
  "version": "0.3.0",
  "identifier": "com.axshare.app",
  "build": {
    "frontendDist": "../../frontend/out/desktop",
    "devUrl": "http://localhost:3000/desktop",
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd ../../frontend && npm run build:tauri"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["axshare"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AXSHARE",
        "url": "index.html",
        "width": 760,
        "height": 720,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "alwaysOnTop": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8000 https://*.axshare.io; img-src 'self' data: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["axshare"],
        "name": "AXSHARE Secure File",
        "description": "File protetto AXSHARE",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 AXSHARE",
    "category": "Productivity",
    "shortDescription": "Secure E2E encrypted file sharing",
    "longDescription": "AXSHARE is a zero-knowledge encrypted file sharing platform.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 },
        "windowPosition": { "x": 400, "y": 100 },
        "appPosition": { "x": 170, "y": 220 },
        "applicationFolderPosition": { "x": 490, "y": 220 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "wix": null,
      "nsis": {
        "languages": ["Italian", "English"],
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      }
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }
  }
}
