# AXSHARE — Production env template
# Copia in .env.prod e sostituisci i placeholder. NON committare .env.prod

# Database
POSTGRES_DB=axshare_prod
POSTGRES_USER=axshare
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# MinIO
MINIO_ROOT_USER=axshare_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Backend (config legge DATABASE_URL, REDIS_URL, ecc.)
SECRET_KEY=CHANGE_ME_JWT_SECRET_64CHARS_MINIMUM
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem

# Vault (opzionale in prod, richiesto dall'app)
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
VAULT_MOUNT_PATH=axshare

# App
DOMAIN=app.axshare.io
FRONTEND_URL=https://app.axshare.io
ALLOWED_ORIGINS=["https://app.axshare.io"]
APP_ENV=production
LOG_LEVEL=info

# GDPR
DATA_RETENTION_DAYS=365

# Sentry (opzionale)
SENTRY_DSN=

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASS
GRAFANA_ROOT_URL=https://grafana.axshare.io

# Alertmanager (email per alert)
ALERT_EMAIL_CRITICAL=admin@axshare.io
ALERT_EMAIL_WARNING=admin@axshare.io
ALERT_EMAIL_SECURITY=security@axshare.io

# Backup (pg_backup con profilo backup)
BACKUP_GPG_RECIPIENT=backup@axshare.io
BACKUP_S3_BUCKET=
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_HOURS=26
