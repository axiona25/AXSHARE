# AXSHARE — Test environment (es. pytest con servizi Docker)
# Usato da backend/tests quando presente

APP_NAME=AXSHARE
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=test

DATABASE_URL=postgresql+asyncpg://axshare:axshare_password@localhost:5432/axshare_test
REDIS_URL=redis://:axshare_redis_password@localhost:6379/1

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_FILES=axshare-files-test
MINIO_BUCKET_KEYS=axshare-keys-test
MINIO_SECURE=false

VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_MOUNT_PATH=axshare

SECRET_KEY=test-secret-key-do-not-use-in-production
ALLOWED_ORIGINS=["http://localhost:3000"]
